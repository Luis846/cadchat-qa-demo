          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API responds successfully', () =>{\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "\r",
              "pm.test('Response is JSON', () => {\r",
              "    pm.response.to.be.json\r",
              "})\r",
              "\r",
              "pm.test('Response contains expected fields', () => {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response).to.have.property('id')\r",
              "    pm.expect(response).to.have.property('title')\r",
              "    pm.expect(response).to.have.property('body')\r",
              "})\r",
              "\r",
              "pm.test('Response time is under 2 seconds', () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000)\r",
              "})"
            ],
