  "item": [
    {
      "name": "Get All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', ()=>{\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "\r",
              "pm.test('Array contains 100 posts', () => {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response).to.have.lengthOf(100)\r",
              "})\r",
              "\r",
              "pm.test('Each post has required fields', ()=>{\r",
              "    const response = pm.response.json()\r",
              "    response.forEach((post) => {\r",
              "        pm.expect(post).to.have.property('id')\r",
              "        pm.expect(post).to.have.property('title')\r",
              "        pm.expect(post).to.have.property('body')\r",
              "        pm.expect(post).to.have.property('userId')\r",
              "    })\r",
              "\r",
              "})\r",
              "\r",
              "\r",
              "pm.test('Response time is under 2 seconds', ()=>{\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000)\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/posts",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
            "typicode",
            "com"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Single Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () =>{\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "\r",
              "pm.test('Response has correct structure', () => {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response).to.have.property('id')\r",
              "    pm.expect(response).to.have.property('title')\r",
              "    pm.expect(response).to.have.property('body')\r",
              "    pm.expect(response).to.have.property('userId')\r",
              "})\r",
              "\r",
              "pm.test('title is a non empty string', () => {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response).to.have.property('title')\r",
              "    pm.expect(typeof response.title).to.equal('string')\r",
              "    pm.expect(response.title).to.not.be.empty\r",
              "})\r",
              "\r",
              "pm.test('response time is under 2 seconds', () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000)\r",
              "})\r",
              "\r",
              "//Save the post ID for use in later requests\r",
              "pm.collectionVariables.set('postId', pm.response.json().id)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
