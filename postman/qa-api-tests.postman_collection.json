    {
      "name": "Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status code is 201 created', () => {\r",
              "    pm.response.to.have.status(201)\r",
              "})\r",
              "\r",
              "pm.test('Response contains created post data', () => {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response).to.have.property('id')\r",
              "    pm.expect(response.title).to.equal('QA Automation Test Post')\r",
              "    pm.expect(response.body).to.equal('This post was created by an automated API test')\r",
              "    pm.expect(response.userId).to.equal(1)\r",
              "})\r",
              "\r",
              "pm.test('New post has an ID assigned', () => {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response.id).to.be.a('number')\r",
              "    pm.expect(response.id).to.be.above(0)\r",
              "})\r",
              "\r",
              "pm.test('Response time is under 2 seconds', () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000)\r",
              "})\r",
              "\r",
              "//save the new post ID for use in later requests\r",
              "const response = pm.response.json()\r",
              "if (response && response.id){\r",
              "    pm.collectionVariables.set('newPostId', response.id)\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
